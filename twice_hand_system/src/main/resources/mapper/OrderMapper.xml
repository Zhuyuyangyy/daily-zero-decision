<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace必须和OrderMapper接口全类名一致 -->
<mapper namespace="com.campus.secondhand.mapper.OrderMapper">

    <!-- 1. 按买家ID查订单 -->
    <select id="selectByBuyerId" parameterType="java.lang.Long" resultType="com.campus.secondhand.entity.Order">
        SELECT * FROM `order` WHERE buyer_id = #{buyerId}
    </select>

    <!-- 2. 按卖家ID查订单 -->
    <select id="selectBySellerId" parameterType="java.lang.Long" resultType="com.campus.secondhand.entity.Order">
        SELECT * FROM `order` WHERE seller_id = #{sellerId}
    </select>

    <!-- 3. 按ID查订单 -->
    <select id="selectById" parameterType="java.lang.Long" resultType="com.campus.secondhand.entity.Order">
        SELECT * FROM `order` WHERE id = #{id}
    </select>

    <!-- 4. 插入订单 -->
    <insert id="insert" parameterType="com.campus.secondhand.entity.Order">
        INSERT INTO `order` (
            buyer_id, seller_id, goods_id, status, create_time, update_time
        ) VALUES (
                     #{buyerId}, #{sellerId}, #{goodsId}, #{status}, NOW(), NOW()
                 )
    </insert>

    <!-- 5. 更新订单 -->
    <update id="updateById" parameterType="com.campus.secondhand.entity.Order">
        UPDATE `order`
        SET status = #{status}, update_time = NOW()
        WHERE id = #{id}
    </update>

</mapper>